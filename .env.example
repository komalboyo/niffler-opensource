# LLM for auto-categorization (optional — works without it, you just tag manually)
# Any OpenAI-compatible provider: OpenAI, Gemini, Grok, Groq, Anthropic, Ollama
XBRAIN_LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
XBRAIN_LLM_API_KEY=your_api_key_here
XBRAIN_LLM_MODEL=gemini-2.5-flash

# Server port (default 3333)
XBRAIN_PORT=3333
