{
  "manifest_version": 3,
  "name": "Niffler",
  "description": "Save tweets to your Niffler knowledge graph",
  "version": "0.1.0",
  "icons": {
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "permissions": ["activeTab", "storage"],
  "host_permissions": ["http://localhost:3333/*"],
  "content_scripts": [
    {
      "matches": ["https://x.com/*", "https://twitter.com/*"],
      "js": ["content.js"],
      "css": ["content.css"]
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "web_accessible_resources": [
    {
      "resources": ["icon48.png"],
      "matches": ["https://x.com/*", "https://twitter.com/*"]
    }
  ]
}
